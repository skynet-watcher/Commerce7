# Public URL of the Hono API (browser must reach this from the merchant’s network).
# For local dev with both servers on your machine, default in code is http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001
#
# When testing via ngrok / public tunnel, set to your API tunnel URL, e.g.:
# NEXT_PUBLIC_API_URL=https://abcd-1234.ngrok-free.app
