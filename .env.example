# Copy to .env and fill in (never commit .env).
# Names are generic; align with your stack and Commerce7 ADC settings.

# App / tunnel (local dev often uses ngrok, Cloudflare Tunnel, etc.)
APP_BASE_URL=http://localhost:3000
# OAuth redirect registered in App Development Center
OAUTH_REDIRECT_URL=${APP_BASE_URL}/oauth/callback

# From Commerce7 App Development Center (example names — use what ADC shows)
COMMERCE7_CLIENT_ID=
COMMERCE7_CLIENT_SECRET=
# API base if you wrap it (official API host is typically api.commerce7.com)
# COMMERCE7_API_BASE=https://api.commerce7.com

# Optional: session / encryption for your app
# SESSION_SECRET=
