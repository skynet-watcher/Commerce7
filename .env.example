# Copy to `.env` in the **repo root** (never commit `.env`).

# --- apps/api (Hono) defaults to PORT 3001; apps/web (Next.js) uses 3000 ---
PORT=3001

# PostgreSQL (required for multi-tenant persistence — no SQLite in prod path)
DATABASE_URL=postgresql://user:pass@localhost:5432/commerce7_app_dev

# Dedicated URL for integration tests (recommended: separate DB from dev so TRUNCATE never hits real data)
# TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/commerce7_test

# Public URL of your API (use ngrok during dev — see docs/STACK.md)
APP_BASE_URL=http://localhost:3001
# Must match a redirect URL in App Development Center
OAUTH_REDIRECT_URL=http://localhost:3001/oauth/callback

# From Commerce7 App Development Center (Basic Auth username = app id, password = app secret)
COMMERCE7_CLIENT_ID=
COMMERCE7_CLIENT_SECRET=
# Defaults to https://api.commerce7.com/v1 — include /v1
# COMMERCE7_API_BASE=https://api.commerce7.com/v1
# Force mock client even when id/secret are set (never use in production)
# COMMERCE7_USE_MOCK=1

# Optional — sync / reconcile / analytics operator guard (set in production)
# INTERNAL_API_TOKEN=

# Optional — ADC Install/Uninstall URL Basic auth (set BOTH or neither)
# LIFECYCLE_BASIC_USER=
# LIFECYCLE_BASIC_PASSWORD=

# --- apps/web (Next.js Integration console) — copy apps/web/.env.example → apps/web/.env.local
# If the browser cannot reach localhost:3001 (e.g. only API is tunneled), set:
# NEXT_PUBLIC_API_URL=https://your-api-tunnel.example

# Optional — ADC webhook “Advanced” HTTP Basic (set BOTH or neither)
# WEBHOOK_BASIC_USER=
# WEBHOOK_BASIC_PASSWORD=

# Optional
# SESSION_SECRET=
